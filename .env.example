# Porta exposta no host para acesso remoto (padrão: 8080)
APP_PORT=8080

# ── E-mail (backup de avaliações e notificações) ──────────────────────────────
# Conta Gmail que VAI ENVIAR os e-mails (crie uma conta dedicada ou use App Password)
SMTP_USER=seuemail@gmail.com
# App Password do Gmail (Configurações > Segurança > Senhas de app)
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# E-mail que RECEBE as notificações de avaliação
NOTIFY_EMAIL=joaoreisfreitas@gmail.com
